# =========================
# Sistema Infra — Produção
# =========================

PORT=3001
NODE_ENV=production

# Credenciais admin (exclusão de pedidos)
ADMIN_LOGIN=adm
ADMIN_PASSWORD=adm123

# Proteção opcional da API
# API_KEY=troque-por-uma-chave-forte

# =========================
# PostgreSQL (DigitalOcean Managed Database)
# Cole a connection string do painel Digital Ocean
# =========================
DATABASE_URL=postgresql://doadmin:SENHA@HOST:25060/defaultdb?sslmode=require
PGSSL=true

# Frontend (só no build — se API e site no mesmo domínio, deixe /api)
# VITE_API_URL=/api
# VITE_API_KEY=
